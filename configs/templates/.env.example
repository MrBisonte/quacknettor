# Example environment variables for duckEL.
# Copy this file to .env and fill in your own values.
# .env is gitignored and will not be committed.
#
# Pipeline configs reference these via __ENV:VAR tokens (see configs/pipelines.yml).

# --- PostgreSQL ---
DUCKEL_PG_PASSWORD=your_postgres_password_here

# --- Snowflake (optional) ---
DUCKEL_SF_USER=your_username
DUCKEL_SF_PASSWORD=your_password
DUCKEL_SF_ACCOUNT=your_account
DUCKEL_SF_DATABASE=your_database
DUCKEL_SF_SCHEMA=PUBLIC
DUCKEL_SF_WAREHOUSE=your_warehouse

# --- AWS S3 (optional; omit if using an IAM role) ---
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Note: the integration test matrix (configs/pipelines_integration.yml) currently
# references the Snowflake vars without the DUCKEL_ prefix (SF_USER, SF_PASSWORD, ...).
# This inconsistency is tracked for cleanup; set both prefixes if running those tests.
